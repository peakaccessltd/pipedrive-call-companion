PORT=8787
WEBHOOK_SECRET=replace-with-shared-secret
DATABASE_URL=postgres://user:password@host:5432/dbname

# Optional Pipedrive write-back from webhook (if you want webhook to directly set dm_eligible)
PIPEDRIVE_BASE_URL=https://your-company.pipedrive.com
PIPEDRIVE_API_TOKEN=replace-with-pipedrive-token
PERSON_DM_ELIGIBLE_FIELD_KEY=replace-with-person-custom-field-key

# Trigger validation for Call Disposition option
CALL_DISPOSITION_TRIGGER_OPTION_ID=6
CALL_DISPOSITION_TRIGGER_LABEL=LinkedIn Outreach next step

# Admin UI auth (required to use /admin)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-strong-password
